<?xml version="1.0" encoding="utf-8"?>
<!-- Local HTTPS (.lvh.me via Caddy) is already trusted via system CA when caddy trust is run.
     Cleartext is disabled; debug builds may still pin user CAs. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>
