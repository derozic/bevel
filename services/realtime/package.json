{
  "name": "@bevel/realtime",
  "version": "0.1.0",
  "private": true,
  "description": "BEVEL realtime transport — websocket, presence, live sessions",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.7",
    "@colyseus/ws-transport": "^0.17.8",
    "colyseus": "^0.17.8",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@colyseus/sdk": "^0.17.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "nx": {
    "name": "realtime",
    "targets": {
      "dev": { "continuous": true }
    }
  }
}