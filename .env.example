# ── Platform ────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-in-production-min-32-chars
NODE_ENV=development

# Tenant app (apps/web)
WEB_PORT=43200
NEXTAUTH_URL=https://demo.bevel.lvh.me
AUTH_URL=https://demo.bevel.lvh.me

# Operator console (apps/admin)
ADMIN_PORT=43201
ADMIN_URL=https://admin.bevel.lvh.me

# Realtime transport (services/realtime)
REALTIME_PORT=43208
REALTIME_URL=https://realtime.bevel.lvh.me

# Domain service (services/domains)
DOMAINS_PORT=43209
BEVEL_CNAME_TARGET=cname.bevel.com

# OAuth (tenant apps inherit tenant auth policy; platform defaults)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Declarative tenants root (default: ./tenants)
BEVEL_TENANTS_ROOT=./tenants

# Doctor offline mode (skip DNS/SSL/health probes)
# BEVEL_DOCTOR_OFFLINE=1

# Dev tenant overrides (comma-separated host → tenant slug)
BEVEL_DEV_TENANTS=demo.bevel.lvh.me:demo,bevel.acme.lvh.me:acme