# ── Platform ────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-in-production-min-32-chars
NODE_ENV=development

# Tenant app (apps/web)
WEB_PORT=43200
NEXTAUTH_URL=https://bevel.lvh.me
AUTH_URL=https://bevel.lvh.me

# Operator console (apps/admin)
ADMIN_PORT=43201
ADMIN_URL=https://admin.bevel.lvh.me

# Realtime transport (services/realtime)
REALTIME_PORT=43208
REALTIME_URL=https://realtime.bevel.lvh.me
NEXT_PUBLIC_REALTIME_URL=https://realtime.bevel.lvh.me

# Domain service (services/domains)
DOMAINS_PORT=43209
BEVEL_CNAME_TARGET=cname.bevel.com

# Control plane (services/api) + operator/agent internal calls
API_PORT=43203
BEVEL_API_URL=https://api.bevel.lvh.me
NEXT_PUBLIC_BEVEL_API_URL=https://api.bevel.lvh.me
# Shared secret for admin proxy + fleet writes (1Password: BEVEL FLEET_INTERNAL_API_KEY)
FLEET_INTERNAL_API_KEY=

# OTP abuse controls (optional overrides)
# OTP_DEST_COOLDOWN_MS=60000
# OTP_IP_MAX_HITS=10
# OTP_IP_WINDOW_MS=3600000

# OAuth (tenant apps inherit tenant auth policy; platform defaults)
# Google Cloud Console → Authorized redirect URIs must include:
#   https://bevel.lvh.me/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GOOGLE_HD=derozic.com
AUTH_TRUST_HOST=true
# Share session across org hosts after platform login (local multi-tenant)
AUTH_COOKIE_DOMAIN=.lvh.me
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Declarative tenants root (resolved from monorepo; relative paths are cwd-safe)
BEVEL_TENANTS_ROOT=./tenants

# Doctor offline mode (skip DNS/SSL/health probes)
# BEVEL_DOCTOR_OFFLINE=1

# Dev tenant overrides (comma-separated host → tenant slug)
BEVEL_DEV_TENANTS=bevel.lvh.me:demo,demo.bevel.lvh.me:demo,bevel.acme.lvh.me:acme